# Copy this file to .env and fill in the values
# IMPORTANT: Change ALL placeholder values before running in any environment

# PostgreSQL
POSTGRES_USER=weather_user
POSTGRES_PASSWORD=change_this_to_a_strong_password
POSTGRES_DB=weather_db

# Backend — DATABASE_URL must match POSTGRES_* values above
DATABASE_URL=postgresql://weather_user:change_this_to_a_strong_password@db:5432/weather_db
SECRET_KEY=change_this_to_a_random_32_character_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000

# OpenAI (required for the chat agent)
OPENAI_API_KEY=sk-...your_key_here...
